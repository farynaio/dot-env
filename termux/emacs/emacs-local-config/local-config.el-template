(setq-default calendar-holidays (append
                                 ;; calendar-holidays
                                 ;; japanese-holidays
                                 polish-holidays
                                 english-holidays
                                 christian-holidays))

(setq-default org-capture-templates
  `(
     ("a" "Article" plain (file ,my/org-pocket-download-file-path)
       "* %?"
       :prepend t :kill-buffer nil)
     ("c" "Contact" entry (file+headline ,my/org-contacts-file-path "Friends") ;,(expand-file-name "contacts.org.gpg" org-directory))
       "* %(org-contacts-template-name)
:PROPERTIES:
:COMPANY:
:ROLE:
:EMAIL: %(org-contacts-template-email)
:MOBILE:
:WORK_PHONE:
:ADDRESS:
:WWW:
:_BIRTHDAY:
:I_TOLD_THEM_EMAIL:
:I_TOLD_THEM_PHONE:
:WHERE_MEET:
:CREATED: [%<%Y-%m-%d %a>]
:END:"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("s" "Business Idea" entry (file+headline ,my/org-ideas-file-path "Ideas")
       "* %?
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:END:

** Brainstorming
** Marketing
*** Lead generation
** Monetization
** Analyse
*** SWOT
**** Strengths
**** Weaknesses
**** Opportunities
**** Treats
*** Six Forces Model
**** Competition
**** New Entrants
**** End Users / Buyers
**** Suppliers
**** Complementary Products

"
       :prepend t :empty-lines-after 0 :kill-buffer nil)

     ("t" "Tasks")
     ("tt" "Todo" entry (file+headline ,my/org-tasks-file-path "Tasks")
       "* TODO %(my/org-priority-cookie-print) %?
SCHEDULED: <%<%Y-%m-%d %a>>
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:EFFORT: %^{What Effort: |0:15|0:30|1:00|2:00|4:00}
:END:
"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("tb" "Backlog" entry (file+headline ,my/org-backlog-file-path "Backlog")
       "* TODO %?
SCHEDULED: <%<%Y-%m-%d %a>>
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:EFFORT: %^{What Effort: |0:15|0:30|1:00|2:00|4:00}
:END:
"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("ti" "Inbox" entry (file ,my/org-inbox-file-path)
       "* TODO %?
SCHEDULED: <%<%Y-%m-%d %a>>
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:EFFORT: %^{What Effort: |0:15|0:30|1:00|2:00|4:00}
:END:
"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("tm" "Maybe / Someday" entry (file+headline ,my/org-tasks-maybe-someday-file-path "Maybe / Someday")
       "* TODO %?
SCHEDULED: <%<%Y-%m-%d %a>>
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:EFFORT: %^{What Effort: |0:15|0:30|1:00|2:00|4:00}
:END:
"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("tr" "Repeatable Tasks" entry (file+headline ,my/org-tasks-file-path "Tasks")
       "* TODO %?
SCHEDULED: <%<%Y-%m-%d %a .+2d/4d>>
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:END:
"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("th" "Habit" entry (file+headline ,my/org-tasks-file-path "Tasks")
       "* TODO %?
SCHEDULED: <%<%Y-%m-%d %a .+1d>>
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:STYLE: habit
:END:
"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("tw" "Waiting" entry (file+headline ,my/org-tasks-file-path "Tasks")
       "* WAITING %?
DEADLINE: <%<%Y-%m-%d %a>>
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:END:
"
       :prepend t :empty-lines-after 1 :kill-buffer nil)

     ;;   ("l" "Dating Log" entry (file+headline ,my/org-journal-dating-file-path "Journal Dating")
     ;; "* [%<%Y-%m-%d %a>]\n%?
     ;; "
     ;; :prepend t :jump-to-captured t :empty-lines-after 0 :kill-buffer t)

     ("m" "Media" entry (file+headline ,my/org-media-file-path "Media")
       "* TODO %\\3 \"%\\1\" %\\2 %? %^g
:PROPERTIES:
:CREATED: [%<%Y-%m-%d %a>]
:TITLE: \"%^{What title: }\"
:AUTHOR: %^{What author: }
:TYPE: %^{What type: |BOOK|AUDIO|ARTICLE|MOVIE|PODCAST|YOUTUBE}
:WHERE: %^{Where do I have it: |none|cloud|kindle|audible|eBook|book|audio|youtube}
:RECOMMENDED: %^{Who recommended: }
:END:
"
       :prepend t :jump-to-captured nil :empty-lines-after 1 :kill-buffer nil)

     ;;   ("o" "Quote" entry (file+headline ,my/org-quotes-file-path "Quotes")
     ;; "* %?
     ;; "
     ;; :prepend nil :empty-lines-after 2 :kill-buffer t)

;;      ("p" "Blog post" entry (file+headline ,my/org-blog-file-path "Posts")
;;        "* \"%?\"
;; :PROPERTIES:
;; :CREATED: [%<%Y-%m-%d %a>]
;; :END:
;; "
;;        :prepend t :empty-lines-after 1 :kill-buffer nil)

     ("r" "Life review")
     ("rw" "Weekly" entry (file+headline ,my/org-review-file-path "Review Life")
       "* [%<%Y-%m-%d>]                                                 :WEEKLY:
:PROPERTIES:
:CREATED: [%<%Y-%m-%d>]
:END:

- What lessons I learned this week?
  -

- Why did this happened? (either positive or negative)
  -

- What is important to me now?
  -

- What is nr #1 on my priority list?
  -

- What are the goals for the next week?
  - "
       :prepend t :empty-lines-after 2 :jump-to-captured nil)

     ("rm" "Monthly" entry (file+headline ,my/org-review-file-path "Review Life")
       "* [%<%Y-%m-%d>]                                                 :MONTHLY:
:PROPERTIES:
:CREATED: [%<%Y-%m-%d>]
:END:

- What lessons I learned this month?
  -

- Why did this happened? (either positive or negative)
  -

- What is important to me now?
  -

- What is nr #1 on my priority list?
  -

- What are the goals for the next month?
  - "
       :prepend t :empty-lines-after 2 :jump-to-captured t)

     ("rh" "Review 6-month" entry (file+headline ,my/org-review-file-path "Review Life")
       "* [%<%Y-%m-%d>]                                                 :HALF-YEAR:
:PROPERTIES:
:CREATED: [%<%Y-%m-%d>]
:END:

Wheel of life:
- finances ::
- health ::
- relationships ::
- fullfillment ::

- What lessons I learned this 6th months?
  -

- Why did this happened? (either positive or negative)
  -

- What is important to me now?
  -

- What is nr #1 on my priority list?
  -

- What are the goals for the next 6th months?
  - "
       :prepend t :empty-lines-after 2 :jump-to-captured t)

     ("ry" "Yearly" entry (file+headline ,my/org-review-file-path "Review Life")
       "* [%<%Y-%m-%d%a>]                                                 :YEARLY:
:PROPERTIES:
:CREATED: [%<%Y-%m-%d>]
:END:

Wheel of life:
- finances ::
- health ::
- relationships ::
- fullfillment ::

- What lessons I learned this year?
  -

- Why did this happened? (either positive or negative)
  -

- What is important to me now?
  -

- What is nr #1 on my priority list?
  -

- What are the goals for the next year?
  - "
       :prepend t :empty-lines-after 2 :jump-to-captured t)

