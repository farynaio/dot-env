;; -*- mode: emacs-lisp -*-

;; mandatory
(setq my/tmp-dir (expand-file-name "tmp" user-emacs-directory))

;; optional, required for GPG
(defconst my/epa-file-encrypt-to-default '(""))
(setq-default mml-secure-openpgp-signers '(""))

(setq my/downloads-dir (if (eq system-type 'android) (expand-file-name "downloads" "~") (expand-file-name "Downloads" "~")))
(setq my/elfeed-org-feeds-files (list (expand-file-name "feeds.org" "~/Sync/elfeed")))
(setq my/elfeed-db-folder "~/Sync/elfeed") ; for index and data/

;; optional
(setq my/org-roam-dir (expand-file-name "~/my-roam"))
(setq my/evil-enable nil)
(setq my/html-enable nil) ; advanced
(setq my/js-enable nil) ; advanced
(setq my/python-enable nil)
(setq my/go-enable nil)
(setq my/php-enable nil) ; requires html
(setq my/kotlin-enabled nil)

(defvar my/org-base-path "~/Documents/emacs/org")
(setq-default org-directory (expand-file-name "orgs" my/org-base-path))
(setq my/org-agenda-directory "~/Documents/emacs/tasks")
(defvar org-gpg-directory (expand-file-name "private" my/org-base-path))
(defvar my/org-backlog-file-path (expand-file-name "backlog.org.gpg" my/org-agenda-directory))
(defvar my/org-events-file-path (expand-file-name "events.org.gpg" my/org-agenda-directory))
(defvar my/org-inbox-file-path (expand-file-name "Inbox.org" my/org-agenda-directory))
(defvar my/org-contacts-file-path (expand-file-name "contacts.org.gpg" my/org-agenda-directory))
(defvar my/org-tasks-file-path (expand-file-name "tasks.org.gpg" my/org-agenda-directory))
(defvar my/org-taxes-file-path (expand-file-name "taxes.org.gpg" my/org-agenda-directory))
(defvar my/org-temp-file-path (expand-file-name "Temp.org" my/org-agenda-directory))
(defvar my/org-archive-tasks-path (expand-file-name "tasks-archive.org.gpg" my/org-agenda-directory))
(defvar my/org-tasks-maybe-someday-file-path (expand-file-name "maybe-someday.org.gpg" my/org-agenda-directory))
(defvar my/org-pocket-download-file-path (expand-file-name "Download.org" "~/Sync/org-agenda-repo/pocket"))
(defvar my/org-active-projects nil)
(defvar my/org-ideas-file-path (expand-file-name "ideas.org.gpg" org-directory))
(defvar my/org-media-file-path (expand-file-name "media.org.gpg" org-directory))
(defvar my/coaching-dir (expand-file-name "coaching" org-gpg-directory))
(defvar my/org-review-file-path (expand-file-name "life-reviews.org.gpg" my/coaching-dir))
(defvar my/org-goals-file-path (expand-file-name "goals.org.gpg" my/coaching-dir))
(defvar my/ledger-base-path (expand-file-name "ledger" my/org-base-path))
(defvar my/ledger-private-path (expand-file-name "private" my/ledger-base-path))
(defvar my/ledger-personal-path (expand-file-name "private.ledger.gpg" my/ledger-private-path))

(setq-default org-refile-targets
  `((,my/org-backlog-file-path :maxlevel . 1)
     (,my/org-tasks-maybe-someday-file-path :maxlevel . 1)
     (,my/org-tasks-file-path :maxlevel . 1)
     (,my/org-taxes-file-path :maxlevel . 1)
     (,my/org-temp-file-path :maxlevel . 1)
     (,my/org-ideas-file-path :maxlevel . 1)))

(setq-default org-agenda-files `(,my/org-tasks-file-path))

